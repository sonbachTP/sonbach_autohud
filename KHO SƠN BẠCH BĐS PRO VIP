  <script>
    function toggleExclusive(id){
      const blocks = document.querySelectorAll('.toggle-block');
      blocks.forEach(block => {
        if(block.id === id){
          block.classList.toggle('open');
        } else {
          block.classList.remove('open');
        }
      });
    }

    function toggleDeepBox(){
      const box = document.getElementById('deepBox');
      if(box){
        box.classList.toggle('show');
      }
    }

    function showAssetPanel(panelId, btn, type){
      document.querySelectorAll('.asset-panel').forEach(p => p.classList.remove('show'));
      const panel = document.getElementById(panelId);
      if(panel) panel.classList.add('show');

      document.querySelectorAll('.filter-tab').forEach(b => {
        b.classList.remove('active-under','active-mid','active-over');
      });

      if(type === 'under') btn.classList.add('active-under');
      if(type === 'mid') btn.classList.add('active-mid');
      if(type === 'over') btn.classList.add('active-over');
    }

    function closePopup(){
      const popup = document.getElementById('successPopup');
      if(popup) popup.classList.remove('show');
      const url = new URL(window.location.href);
      url.searchParams.delete('success');
      window.history.replaceState({}, '', url.pathname);
    }

    (function(){
      const params = new URLSearchParams(window.location.search);
      if(params.get('success') === '1'){
        const popup = document.getElementById('successPopup');
        if(popup) popup.classList.add('show');
      }
    })();
  </script>

