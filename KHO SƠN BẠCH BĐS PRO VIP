<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SƠN BẠCH BĐS VIP PRO</title>
  <meta name="description" content="Sơn Bạch BĐS VIP PRO - Kho bất động sản chọn lọc, hàng kín, NDA, hồ sơ chọn lọc, khách thật ưu tiên." />
  <link rel="icon" type="image/jpeg" href="https://raw.githubusercontent.com/sonbachTP/sonbach_autohud/main/1JL1MVP2F_3ASM3R.jpeg">
  <link rel="apple-touch-icon" href="https://raw.githubusercontent.com/sonbachTP/sonbach_autohud/main/1JL1MVP2F_3ASM3R.jpeg">
  <meta name="theme-color" content="#0b0b0b">
  <meta property="og:image" content="https://raw.githubusercontent.com/sonbachTP/sonbach_autohud/main/1JL1MVP2F_3ASM3R.jpeg">

  <style>
    :root{
      --bg:#040404;
      --bg-soft:#0b0b0b;
      --card:#111111;
      --card2:#171717;
      --gold:#ffd76a;
      --gold2:#c9981c;
      --gold3:#fff1bc;
      --text:#f7efd9;
      --muted:#ccb982;
      --line:rgba(255,215,106,.16);
      --line-strong:rgba(255,215,106,.28);
      --shadow:0 0 24px rgba(255,215,106,.10), 0 0 60px rgba(201,152,28,.07);

      --c-under50:#7fe0ff;
      --c-under50-bg:rgba(127,224,255,.08);

      --c-mid:#ffcf5a;
      --c-mid-bg:rgba(255,207,90,.10);

      --c-over:#ff8f8f;
      --c-over-bg:rgba(255,143,143,.08);
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top center, rgba(255,215,106,.10), transparent 20%),
        radial-gradient(circle at 20% 15%, rgba(255,215,106,.04), transparent 28%),
        linear-gradient(180deg, #020202 0%, #090909 42%, #030303 100%);
      overflow-x:hidden;
    }

    a{text-decoration:none;color:inherit}

    .topbar{
      position:sticky;
      top:0;
      z-index:90;
      backdrop-filter:blur(14px);
      background:rgba(6,6,6,.84);
      border-bottom:1px solid rgba(255,215,106,.12);
      box-shadow:0 8px 24px rgba(0,0,0,.35);
    }

    .topbar-inner{
      width:min(1220px,92%);
      margin:auto;
      min-height:68px;
      display:flex;
      align-items:center;
      justify-content:center;
      gap:12px;
      padding:10px 0;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      color:var(--gold);
      font-weight:900;
      letter-spacing:1px;
      text-transform:uppercase;
    }

    .brand img{
      width:46px;
      height:46px;
      object-fit:cover;
      border-radius:14px;
      border:1px solid rgba(255,215,106,.22);
      box-shadow:0 0 14px rgba(255,215,106,.12);
      background:#111;
    }

    .brand-text{
      display:flex;
      flex-direction:column;
      line-height:1.12;
      text-align:left;
    }

    .brand-text strong{
      color:var(--gold);
      font-size:15px;
      letter-spacing:.8px;
      text-shadow:0 0 10px rgba(255,215,106,.18);
    }

    .brand-text small{
      color:var(--muted);
      font-size:10px;
      letter-spacing:1.5px;
      margin-top:4px;
    }

    .runner{
      overflow:hidden;
      white-space:nowrap;
      border-top:1px solid rgba(255,215,106,.08);
      border-bottom:1px solid rgba(255,215,106,.1);
      background:rgba(255,215,106,.03);
    }

    .runner-track{
      display:inline-block;
      min-width:200%;
      padding:11px 0;
      color:var(--gold);
      font-size:12px;
      font-weight:900;
      letter-spacing:2px;
      text-transform:uppercase;
      text-shadow:0 0 8px rgba(255,215,106,.18);
      animation:run 28s linear infinite;
    }

    @keyframes run{
      from{transform:translateX(0)}
      to{transform:translateX(-50%)}
    }

    .wrap{
      width:min(1220px,92%);
      margin:auto;
      padding:24px 0 120px;
    }

    .hero{
      position:relative;
      overflow:hidden;
      border-radius:34px;
      padding:44px 20px 36px;
      text-align:center;
      border:1px solid rgba(255,215,106,.15);
      background:
        linear-gradient(rgba(6,6,6,.55), rgba(8,8,8,.82)),
        url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
      box-shadow:0 0 26px rgba(255,215,106,.10), 0 0 60px rgba(201,152,28,.07);
      isolation:isolate;
    }

    .hero::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at center top, rgba(255,215,106,.12), transparent 38%);
      pointer-events:none;
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:34px;
      padding:1px;
      background:linear-gradient(130deg, rgba(255,215,106,0), rgba(255,215,106,.28), rgba(255,215,106,0));
      -webkit-mask:linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite:xor;
              mask-composite:exclude;
      pointer-events:none;
      opacity:.6;
    }

    .hero-bg-sb{
      position:absolute;
      left:50%;
      top:52%;
      transform:translate(-50%,-50%);
      width:min(62vw,520px);
      aspect-ratio:1/1;
      pointer-events:none;
      opacity:.13;
      z-index:0;
      animation:spinSlow 38s linear infinite;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .hero-bg-sb img{
      width:100%;
      max-width:420px;
      object-fit:contain;
      filter:drop-shadow(0 0 18px rgba(255,215,106,.10));
      border-radius:34px;
    }

    @keyframes spinSlow{
      from{transform:translate(-50%,-50%) rotate(0deg)}
      to{transform:translate(-50%,-50%) rotate(360deg)}
    }

    .hero-inner{
      position:relative;
      z-index:2;
    }

    .hero-sub{
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:3px;
      font-size:12px;
      font-weight:900;
      margin-bottom:10px;
    }

    h1{
      margin:0;
      font-size:clamp(32px,5vw,68px);
      line-height:1.05;
      color:#fff7dd;
      text-shadow:0 0 14px rgba(255,215,106,.12);
    }

    .gold{
      color:var(--gold);
      text-shadow:
        0 0 8px rgba(255,215,106,.55),
        0 0 24px rgba(255,215,106,.18),
        0 0 46px rgba(255,215,106,.08);
      animation:goldGlow 2.6s ease-in-out infinite alternate;
    }

    @keyframes goldGlow{
      from{filter:brightness(1)}
      to{filter:brightness(1.13)}
    }

    .hero-desc{
      width:min(840px,100%);
      margin:16px auto 0;
      color:#efdfb0;
      line-height:1.9;
      font-size:15px;
    }

    .hero-badges{
      margin-top:18px;
      display:flex;
      justify-content:center;
      gap:10px;
      flex-wrap:wrap;
    }

    .hero-badges span{
      padding:10px 14px;
      border-radius:999px;
      border:1px solid rgba(255,215,106,.16);
      background:rgba(255,215,106,.08);
      color:var(--gold);
      font-size:12px;
      font-weight:900;
      letter-spacing:.6px;
      text-transform:uppercase;
      box-shadow:0 0 14px rgba(255,215,106,.05);
      backdrop-filter:blur(4px);
    }

    .hero-banner{
      margin-top:18px;
      padding:16px 18px;
      border-radius:20px;
      border:1px solid rgba(255,215,106,.14);
      background:linear-gradient(180deg, rgba(255,215,106,.08), rgba(255,215,106,.03));
      color:#eadcb1;
      box-shadow:0 0 16px rgba(255,215,106,.05);
      line-height:1.8;
      font-size:14px;
      backdrop-filter:blur(4px);
    }

    .hero-banner strong{color:var(--gold)}

    .toggle-block{
      margin-top:18px;
      border:1px solid rgba(255,215,106,.14);
      border-radius:28px;
      background:
        linear-gradient(180deg, rgba(255,215,106,.04), rgba(255,215,106,.015)),
        rgba(10,10,10,.82);
      box-shadow:0 0 16px rgba(255,215,106,.05);
      overflow:hidden;
    }

    .toggle-btn{
      width:100%;
      border:0;
      background:transparent;
      color:#fff2c9;
      text-align:left;
      padding:18px 20px;
      font-size:18px;
      font-weight:900;
      letter-spacing:.4px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      cursor:pointer;
    }

    .toggle-btn span:last-child{
      color:var(--gold);
      font-size:22px;
      line-height:1;
      transition:transform .25s ease;
    }

    .toggle-block.open .toggle-btn span:last-child{
      transform:rotate(45deg);
    }

    .toggle-content{
      display:none;
      padding:0 20px 20px;
      border-top:1px solid rgba(255,215,106,.08);
    }

    .toggle-block.open .toggle-content{
      display:block;
      animation:fadeDown .25s ease;
    }

    @keyframes fadeDown{
      from{opacity:0;transform:translateY(-6px)}
      to{opacity:1;transform:translateY(0)}
    }

    .chips{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:16px;
    }

    .chip{
      padding:10px 14px;
      border-radius:999px;
      border:1px solid rgba(255,215,106,.16);
      background:rgba(255,215,106,.05);
      color:var(--gold);
      font-size:12px;
      font-weight:900;
      letter-spacing:.8px;
      text-transform:uppercase;
      box-shadow:0 0 14px rgba(255,215,106,.04);
    }

    .chip-under{
      color:var(--c-under50);
      border-color:rgba(127,224,255,.32);
      background:var(--c-under50-bg);
      box-shadow:0 0 14px rgba(127,224,255,.06);
    }

    .chip-mid{
      color:var(--c-mid);
      border-color:rgba(255,207,90,.30);
      background:var(--c-mid-bg);
      box-shadow:0 0 14px rgba(255,207,90,.06);
    }

    .chip-over{
      color:var(--c-over);
      border-color:rgba(255,143,143,.28);
      background:var(--c-over-bg);
      box-shadow:0 0 14px rgba(255,143,143,.06);
    }

    .mini-note{
      margin-top:14px;
      color:#e9dcb0;
      line-height:1.8;
      font-size:14px;
    }

    .info-grid{
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:18px;
      margin-top:18px;
    }

    .box{
      border-radius:24px;
      border:1px solid rgba(255,215,106,.14);
      background:rgba(255,255,255,.015);
      padding:18px;
      box-shadow:0 0 14px rgba(255,215,106,.04);
    }

    .box h3{
      margin:0;
      font-size:22px;
      color:#fff1c8;
    }

    .box p{
      margin:12px 0 0;
      color:#eadcb0;
      line-height:1.85;
      font-size:14px;
    }

    .points{
      display:grid;
      gap:10px;
      margin-top:16px;
    }

    .points div{
      padding:12px 14px;
      border-radius:16px;
      border:1px solid rgba(255,215,106,.1);
      background:rgba(255,215,106,.04);
      color:#f0e3bd;
      line-height:1.7;
      font-size:14px;
    }

    .nda-form{
      margin-top:16px;
    }

    .form-grid{
      display:grid;
      grid-template-columns:1fr 1fr 1fr;
      gap:12px;
    }

    .field{
      width:100%;
      min-height:50px;
      border-radius:16px;
      border:1px solid rgba(255,215,106,.14);
      background:#0f0f0f;
      color:#f8efd8;
      padding:14px 14px;
      outline:none;
      font-size:14px;
    }

    .field::placeholder{color:#9f926e}

    .field:focus{
      border-color:rgba(255,215,106,.32);
      box-shadow:0 0 0 2px rgba(255,215,106,.08);
    }

    .agree{
      display:flex;
      align-items:flex-start;
      gap:10px;
      margin-top:14px;
      color:#eadcb0;
      font-size:13px;
      line-height:1.7;
    }

    .agree input{
      margin-top:3px;
      accent-color:#ffd76a;
      transform:scale(1.1);
    }

    .btn-row{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:16px;
    }

    .btn{
      min-height:50px;
      padding:0 16px;
      border-radius:16px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      font-weight:900;
      letter-spacing:.4px;
      transition:.24s ease;
      border:1px solid rgba(255,215,106,.16);
      cursor:pointer;
    }

    .btn-main{
      color:#111;
      background:linear-gradient(90deg,#dcb54a,#ffd76a,#b88413);
      box-shadow:0 0 18px rgba(255,215,106,.18);
    }

    .btn-main:hover{
      transform:translateY(-2px);
      box-shadow:0 0 22px rgba(255,215,106,.25);
    }

    .btn-sub{
      color:var(--gold);
      background:rgba(255,215,106,.05);
    }

    .btn-sub:hover{
      background:rgba(255,215,106,.09);
      border-color:rgba(255,215,106,.24);
    }

    .deep-box{
      display:none;
      margin-top:16px;
      padding:16px;
      border-radius:20px;
      border:1px solid rgba(255,215,106,.14);
      background:linear-gradient(180deg, rgba(255,215,106,.05), rgba(255,215,106,.02));
      box-shadow:0 0 14px rgba(255,215,106,.04);
      color:#f0e3bd;
      line-height:1.8;
      font-size:14px;
    }

    .deep-box.show{
      display:block;
      animation:fadeDown .25s ease;
    }
    .filter-tabs{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:18px;
    }

    .filter-tab{
      min-height:46px;
      padding:0 16px;
      border-radius:999px;
      border:1px solid rgba(255,215,106,.14);
      background:rgba(255,215,106,.04);
      color:#fff2c8;
      font-size:13px;
      font-weight:900;
      letter-spacing:.4px;
      cursor:pointer;
      transition:.22s ease;
    }

    .filter-tab:hover{
      transform:translateY(-1px);
    }

    .filter-tab.active-under{
      color:var(--c-under50);
      border-color:rgba(127,224,255,.34);
      background:rgba(127,224,255,.08);
    }

    .filter-tab.active-mid{
      color:var(--c-mid);
      border-color:rgba(255,207,90,.34);
      background:rgba(255,207,90,.10);
    }

    .filter-tab.active-over{
      color:var(--c-over);
      border-color:rgba(255,143,143,.30);
      background:rgba(255,143,143,.08);
    }

    .asset-panel{
      display:none;
      margin-top:18px;
      border:1px solid rgba(255,215,106,.12);
      border-radius:28px;
      padding:18px;
      background:rgba(255,255,255,.015);
      box-shadow:0 0 18px rgba(255,215,106,.04);
      animation:fadeDown .25s ease;
    }

    .asset-panel.show{
      display:block;
    }

    .group-title{
      display:flex;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:14px;
    }

    .group-title h3{
      margin:0;
      font-size:18px;
      color:#fff0c2;
      text-transform:uppercase;
      letter-spacing:1px;
    }

    .group-title .line{
      flex:1;
      min-width:40px;
      height:1px;
      background:linear-gradient(90deg, rgba(255,215,106,.4), rgba(255,215,106,0));
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
    }

    .card{
      position:relative;
      border-radius:26px;
      overflow:hidden;
      border:1px solid rgba(255,215,106,.14);
      background:
        linear-gradient(180deg, rgba(255,215,106,.06), rgba(255,215,106,.015)),
        linear-gradient(180deg, #141414 0%, #101010 100%);
      box-shadow:0 0 22px rgba(255,215,106,.07);
      transition:transform .28s ease, box-shadow .28s ease, border-color .28s ease;
    }

    .card:hover{
      transform:translateY(-6px);
      border-color:rgba(255,215,106,.28);
      box-shadow:0 0 26px rgba(255,215,106,.14), 0 0 54px rgba(255,215,106,.06);
    }

    .card-top{
      min-height:192px;
      padding:22px 20px 18px;
      background:
        radial-gradient(circle at top right, rgba(255,215,106,.13), transparent 36%),
        linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,0));
      border-bottom:1px solid rgba(255,215,106,.08);
    }

    .tag{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(255,215,106,.16);
      background:rgba(255,215,106,.08);
      color:var(--gold);
      font-size:11px;
      font-weight:900;
      letter-spacing:1px;
      text-transform:uppercase;
      box-shadow:0 0 12px rgba(255,215,106,.05);
    }

    .tag-under{
      color:var(--c-under50);
      border-color:rgba(127,224,255,.32);
      background:var(--c-under50-bg);
    }

    .tag-mid{
      color:var(--c-mid);
      border-color:rgba(255,207,90,.30);
      background:var(--c-mid-bg);
    }

    .tag-over{
      color:var(--c-over);
      border-color:rgba(255,143,143,.28);
      background:var(--c-over-bg);
    }

    .price{
      margin-top:16px;
      font-size:clamp(36px,5vw,50px);
      line-height:1;
      font-weight:900;
      animation:pricePulse 1.8s ease-in-out infinite alternate;
    }

    .price-under{color:var(--c-under50); text-shadow:0 0 10px rgba(127,224,255,.35),0 0 24px rgba(127,224,255,.14)}
    .price-mid{color:var(--c-mid); text-shadow:0 0 10px rgba(255,207,90,.35),0 0 24px rgba(255,207,90,.14)}
    .price-over{color:var(--c-over); text-shadow:0 0 10px rgba(255,143,143,.35),0 0 24px rgba(255,143,143,.14)}

    @keyframes pricePulse{
      from{transform:scale(1)}
      to{transform:scale(1.025)}
    }

    .card-title{
      margin-top:12px;
      font-size:24px;
      font-weight:900;
      line-height:1.25;
      color:#fff4cf;
    }

    .card-sub{
      margin-top:8px;
      color:#d9c796;
      font-size:13px;
      line-height:1.7;
    }

    .card-body{
      padding:18px 20px 22px;
    }

    .meta{
      display:grid;
      gap:10px;
    }

    .meta-item{
      display:flex;
      align-items:flex-start;
      gap:10px;
      font-size:14px;
      line-height:1.75;
      color:#efe3bc;
    }

    .meta-item b{
      min-width:84px;
      color:var(--gold);
    }

    .desc{
      margin-top:14px;
      color:#ddd0a7;
      font-size:14px;
      line-height:1.85;
      min-height:102px;
    }

    .btns{
      display:grid;
      gap:10px;
      margin-top:18px;
    }

    .footer{
      margin-top:28px;
      padding:22px 18px;
      text-align:center;
      border-radius:22px;
      border:1px solid rgba(255,215,106,.12);
      background:rgba(255,215,106,.03);
      color:#e9dbaf;
      line-height:1.85;
      box-shadow:0 0 14px rgba(255,215,106,.05);
    }

    .footer strong{color:var(--gold)}

    .sticky{
      position:fixed;
      left:12px;
      right:12px;
      bottom:12px;
      z-index:100;
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:10px;
    }

    .sticky a{
      min-height:54px;
      border-radius:18px;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:0 8px;
      font-size:14px;
      font-weight:900;
      border:1px solid rgba(255,215,106,.18);
      backdrop-filter:blur(12px);
      box-shadow:0 0 16px rgba(255,215,106,.08);
    }

    .sticky .call{
      color:#111;
      background:linear-gradient(90deg,#ddb64b,#ffd76a,#b88413);
    }

    .sticky .zalo,.sticky .fb{
      color:var(--gold);
      background:rgba(255,215,106,.08);
    }

    .popup-wrap{
      position:fixed;
      inset:0;
      z-index:999;
      display:none;
      align-items:center;
      justify-content:center;
      padding:18px;
      background:rgba(0,0,0,.65);
      backdrop-filter:blur(4px);
    }

    .popup-wrap.show{
      display:flex;
      animation:fadeIn .25s ease;
    }

    @keyframes fadeIn{
      from{opacity:0}
      to{opacity:1}
    }

    .popup{
      width:min(520px,100%);
      border-radius:28px;
      border:1px solid rgba(255,215,106,.18);
      background:
        radial-gradient(circle at top center, rgba(255,215,106,.10), transparent 45%),
        linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01)),
        #0d0d0d;
      box-shadow:0 0 30px rgba(255,215,106,.12), 0 0 80px rgba(0,0,0,.5);
      padding:28px 22px 22px;
      text-align:center;
      color:#f5e9c8;
